{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://github.com/TheAnsarya/SeedLists/schemas/seedlists.catalog.schema.json",
	"title": "SeedLists DAT Catalog",
	"type": "object",
	"required": ["name", "provider", "games"],
	"properties": {
		"name": {
			"type": "string",
			"minLength": 1
		},
		"description": {
			"type": "string"
		},
		"version": {
			"type": "string"
		},
		"author": {
			"type": "string"
		},
		"homepage": {
			"type": "string"
		},
		"system": {
			"type": "string"
		},
		"provider": {
			"type": "string",
			"enum": ["Unknown", "NoIntro", "Tosec", "GoodTools", "Mame", "Mess", "Redump", "PleasureDome"]
		},
		"games": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["name", "roms"],
				"properties": {
					"name": { "type": "string", "minLength": 1 },
					"description": { "type": "string" },
					"publisher": { "type": "string" },
					"year": { "type": "string" },
					"roms": {
						"type": "array",
						"items": {
							"type": "object",
							"required": ["name", "size"],
							"properties": {
								"name": { "type": "string", "minLength": 1 },
								"size": { "type": "integer", "minimum": 0 },
								"crc32": { "type": "string", "pattern": "^[a-fA-F0-9]{8}$" },
								"crc": { "type": "string", "pattern": "^[a-fA-F0-9]{8}$" },
								"md5": { "type": "string", "pattern": "^[a-fA-F0-9]{32}$" },
								"sha1": { "type": "string", "pattern": "^[a-fA-F0-9]{40}$" },
								"status": { "type": "string" }
							},
							"additionalProperties": true
						}
					}
				},
				"additionalProperties": true
			}
		}
	},
	"additionalProperties": true
}
